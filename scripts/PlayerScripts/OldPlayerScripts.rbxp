                                "$path": "StarterPlayerScripts/PlayerModule.module/CameraModule/VRVehicleCamera.lua"
                            },
                            "VehicleCamera": {
                                "$className": "ModuleScript",
                                "$path": [ "StarterPlayerScripts/PlayerModule.module/CameraModule/VehicleCamera.lua", "StarterPlayerScripts/PlayerModule.module/CameraModule/VehicleCamera"],
                            },
                            "ZoomController": {
                                "$className": "ModuleScript",
                                "$path": [ "StarterPlayerScripts/PlayerModule.module/CameraModule/ZoomController.lua", "StarterPlayerScripts/PlayerModule.module/CameraModule/ZoomController" ],
                            }
                        },
                        "ControlModule": {
                            "$className": "ModuleScript",
                            "$path": ["StarterPlayerScripts/PlayerModule.module/ControlModule.lua", "StarterPlayerScripts/PlayerModule.module/ControlModule" ],
                        },
                        "CommonUtils": {
                            "$className": "Folder",
                            "$path": "StarterPlayerScripts/PlayerModule.module/CommonUtils"
                        }
                    }
                }
            }
        }
    }
}
