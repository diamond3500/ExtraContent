{
    "instanceHierarchy": {
        "tree": {
            "$className": "DataModel",
            "StarterPlayer": {
                "StarterPlayerScripts": {
                    "$className": "StarterPlayerScripts",
                    "PlayerModule": {
                        "$className": "ModuleScript",
                        "$path": "StarterPlayerScripts/PlayerModule.module.lua",
                        "CameraModule": {
                            "$className": "ModuleScript",
                            "$path": "StarterPlayerScripts/PlayerModule.module/CameraModule.lua",
                            "BaseCamera": {
                                "$path": "StarterPlayerScripts/PlayerModule.module/CameraModule/BaseCamera.lua"
                            },
                            "BaseOcclusion": {
                                "$path": "StarterPlayerScripts/PlayerModule.module/CameraModule/BaseOcclusion.lua"
                            },
                            "CameraInput": {
                                "$path": "StarterPlayerScripts/PlayerModule.module/CameraModule/CameraInput.lua"
                            },
                            "CameraToggleStateController": {
                                "$path": "StarterPlayerScripts/PlayerModule.module/CameraModule/CameraToggleStateController.lua"
                            },
                            "CameraUI": {
                                "$path": "StarterPlayerScripts/PlayerModule.module/CameraModule/CameraUI.lua"
                            },
                            "CameraUtils": {
                                "$path": "StarterPlayerScripts/PlayerModule.module/CameraModule/CameraUtils.lua"
                            },
                            "ClassicCamera": {
                                "$path": "StarterPlayerScripts/PlayerModule.module/CameraModule/ClassicCamera.lua"
                            },
                            "Invisicam": {
                                "$path": "StarterPlayerScripts/PlayerModule.module/CameraModule/Invisicam.lua"
                            },
                            "LegacyCamera": {
                                "$path": "StarterPlayerScripts/PlayerModule.module/CameraModule/LegacyCamera.lua"
                            },
                            "MouseLockController": {
                                "$path": "StarterPlayerScripts/PlayerModule.module/CameraModule/MouseLockController.lua"
                            },
                            "OrbitalCamera": {
                                "$path": "StarterPlayerScripts/PlayerModule.module/CameraModule/OrbitalCamera.lua"
                            },
                            "Poppercam": {
                                "$path": "StarterPlayerScripts/PlayerModule.module/CameraModule/Poppercam.lua"
                            },
                            "TransparencyController": {
                                "$path": "StarterPlayerScripts/PlayerModule.module/CameraModule/TransparencyController.lua"
                            },
                            "VRBaseCamera": {
                                "$path": "StarterPlayerScripts/PlayerModule.module/CameraModule/VRBaseCamera.lua"
                            },
                            "VRCamera": {
                                "$path": "StarterPlayerScripts/PlayerModule.module/CameraModule/VRCamera.lua"
